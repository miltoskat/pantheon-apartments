---
/* Global IntersectionObserver that activates any element with class="fade-in".
 * Place this once in BaseLayout — components just opt in by adding the class
 * (and optionally data-delay="1|2|3"). The base CSS lives in global.css. */
---

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.12 }
  );

  for (const el of document.querySelectorAll<HTMLElement>(".fade-in")) {
    observer.observe(el);
  }
</script>
